# Shared git config (aliases), deployed to ~/.config/git/config (XDG global).
# Per-machine identity ([user]) goes in ~/.gitconfig via `git config --global`;
# git reads both, and ~/.gitconfig is not committed.
[alias]
	aa = add --all
	st = status
	com = commit
	ch = checkout
	br = branch
	pick = cherry-pick
	fp = format-patch
	la = log --graph --decorate --pretty=oneline --abbrev-commit --all
	ll = log --graph --decorate --pretty=oneline --abbrev-commit
	lf = log --stat --decorate --format=fuller abbrev-commit
	ls = log --graph --pretty=oneline --abbrev-commit
	pr = pull --rebase
	ffm = merge --ff-only
	rc = rebase --continue
	ri = rebase --interactive
[core]
	editor = vim
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[color]
	ui = auto
